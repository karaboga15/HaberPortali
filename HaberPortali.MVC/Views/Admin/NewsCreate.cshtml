@{
    ViewData["Title"] = "Haber Ekle";
    Layout = "_Layout";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card shadow-sm">
            <div class="card-body">
                <h5 class="mb-4 fw-bold">Haber Ekle</h5>
                <form method="post">
                    <div class="mb-3">
                        <label class="form-label">Başlık</label>
                        <input name="title" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">İçerik</label>
                        <textarea name="content" class="form-control" rows="8" required></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Resim URL</label>
                        <input name="imagePath" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Kategori</label>
                        <select name="categoryId" class="form-select" id="catSelect" required></select>
                    </div>
                    <div class="d-flex gap-2">
                        <button class="btn btn-danger">Kaydet</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">İptal</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
const cats = @Html.Raw(ViewBag.Categories ?? "[]");
const sel = document.getElementById('catSelect');
cats.forEach(c => sel.innerHTML += `<option value="${c.id}">${c.name}</option>`);
</script>
}
