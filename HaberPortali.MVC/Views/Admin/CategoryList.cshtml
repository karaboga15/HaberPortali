@{
    ViewData["Title"] = "Kategoriler";
    Layout = "_Layout";
}

<div class="row">
    <div class="col-md-5">
        <div class="card shadow-sm mb-4">
            <div class="card-body">
                <h6 class="fw-bold mb-3">Kategori Ekle</h6>
                <form method="post" asp-action="CategoryCreate">
                    <div class="input-group">
                        <input name="name" class="form-control" placeholder="Kategori adı" required />
                        <button class="btn btn-danger">Ekle</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
    <div class="col-md-7">
        <div class="card shadow-sm">
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead class="table-dark"><tr><th>#</th><th>Ad</th><th></th></tr></thead>
                    <tbody id="catBody"></tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
const cats = @Html.Raw(ViewBag.Categories ?? "[]");
const tbody = document.getElementById('catBody');
cats.forEach(c => {
    tbody.innerHTML += `<tr><td>${c.id}</td><td>${c.name}</td>
        <td><a href="/Admin/CategoryDelete/${c.id}" class="btn btn-sm btn-outline-danger" onclick="return confirm('Silinsin mi?')"><i class="bi bi-trash"></i></a></td></tr>`;
});
</script>
}
