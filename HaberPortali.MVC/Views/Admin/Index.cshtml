@{
    ViewData["Title"] = "Yönetim Paneli";
    Layout = "_Layout";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0"><i class="bi bi-gear"></i> Yönetim Paneli</h4>
    <div>
        <a asp-action="NewsCreate" class="btn btn-danger btn-sm me-2"><i class="bi bi-plus"></i> Haber Ekle</a>
        <a asp-action="CategoryList" class="btn btn-outline-secondary btn-sm">Kategoriler</a>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0" id="newsTable">
            <thead class="table-dark">
                <tr><th>#</th><th>Başlık</th><th>Kategori</th><th>Tarih</th><th>Görüntülenme</th><th></th></tr>
            </thead>
            <tbody id="tbody"></tbody>
        </table>
    </div>
</div>

@section Scripts {
<script>
const news = @Html.Raw(ViewBag.News ?? "[]");
const tbody = document.getElementById('tbody');
news.forEach(n => {
    tbody.innerHTML += `<tr>
        <td>${n.id}</td>
        <td>${n.title}</td>
        <td>${n.categoryId}</td>
        <td>${new Date(n.createdDate).toLocaleDateString('tr-TR')}</td>
        <td>${n.viewCount}</td>
        <td>
            <a href="/Admin/NewsEdit/${n.id}" class="btn btn-sm btn-outline-primary me-1"><i class="bi bi-pencil"></i></a>
            <a href="/Admin/NewsDelete/${n.id}" class="btn btn-sm btn-outline-danger" onclick="return confirm('Silinsin mi?')"><i class="bi bi-trash"></i></a>
        </td>
    </tr>`;
});
</script>
}
