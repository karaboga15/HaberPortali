@{
    ViewData["Title"] = "Haber Düzenle";
    Layout = "_Layout";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card shadow-sm">
            <div class="card-body">
                <h5 class="mb-4 fw-bold">Haber Düzenle</h5>
                <form method="post" id="editForm">
                    <input type="hidden" name="id" id="hId" />
                    <div class="mb-3">
                        <label class="form-label">Başlık</label>
                        <input name="title" id="hTitle" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">İçerik</label>
                        <textarea name="content" id="hContent" class="form-control" rows="8" required></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Resim URL</label>
                        <input name="imagePath" id="hImage" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Kategori</label>
                        <select name="categoryId" id="catSelect" class="form-select" required></select>
                    </div>
                    <div class="d-flex gap-2">
                        <button class="btn btn-danger">Güncelle</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">İptal</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
const news = @Html.Raw(ViewBag.News ?? "{}");
const cats = @Html.Raw(ViewBag.Categories ?? "[]");
document.getElementById('hId').value = news.id;
document.getElementById('hTitle').value = news.title;
document.getElementById('hContent').value = news.content;
document.getElementById('hImage').value = news.imagePath ?? '';
const sel = document.getElementById('catSelect');
cats.forEach(c => sel.innerHTML += `<option value="${c.id}" ${c.id == news.categoryId ? 'selected' : ''}>${c.name}</option>`);
</script>
}
