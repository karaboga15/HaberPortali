@{
    ViewData["Title"] = "Haber Düzenle";
    Layout = "_Layout";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card shadow-sm">
            <div class="card-body">
                <h5 class="mb-4 fw-bold">Haber Düzenle</h5>
                <form method="post" asp-action="NewsEdit" asp-route-id="@Model?.Id">
                    <input type="hidden" name="id" value="@Model?.Id" />
                    <div class="mb-3">
                        <label class="form-label">Başlık</label>
                        <input name="title" class="form-control" value="@Model?.Title" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">İçerik</label>
                        <textarea name="content" class="form-control" rows="8" required>@Model?.Content</textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Resim URL</label>
                        <input name="imagePath" class="form-control" value="@Model?.ImagePath" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Kategori</label>
                        <select name="categoryId" class="form-select" required>
                            @if (ViewBag.Categories != null)
                            {
                                foreach (var cat in ViewBag.Categories)
                                {
                                    <option value="@cat.Id" selected="@(cat.Id == Model?.CategoryId)">@cat.Name</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="d-flex gap-2">
                        <button class="btn btn-danger">Güncelle</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">İptal</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>