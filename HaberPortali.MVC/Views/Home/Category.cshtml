@{
    ViewData["Title"] = "Kategori Haberleri";
}

<h3 class="mb-4">Kategori Haberleri</h3>
<div class="row" id="catNews"></div>

@section Scripts {
<script>
const news = @Html.Raw(ViewBag.News ?? "[]");
const c = document.getElementById('catNews');
if (!news.length) { c.innerHTML = '<div class="col-12 text-center text-muted"><h5>Haber bulunamadı.</h5></div>'; }
else news.forEach(n => {
    c.innerHTML += `<div class="col-md-4 mb-4">
        <div class="card news-card h-100">
            <div class="card-body">
                <h5>${n.title}</h5>
                <p class="text-muted small">${n.content.substring(0,100)}...</p>
                <a href="/Home/Detail/${n.id}" class="btn btn-sm btn-outline-danger">Oku</a>
            </div>
        </div>
    </div>`;
});
</script>
}
