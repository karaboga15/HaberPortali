@{
    ViewData["Title"] = "Haber Detay";
}

<div id="newsDetail"></div>
<hr />
<h5>Yorumlar</h5>
<div id="commentList" class="mb-4"></div>

@if (Context.Session.GetString("token") != null)
{
    <div class="card">
        <div class="card-body">
            <h6>Yorum Yap</h6>
            <textarea id="commentText" class="form-control mb-2" rows="3" placeholder="Yorumunuz..."></textarea>
            <button class="btn btn-danger btn-sm" onclick="addComment()">Gönder</button>
        </div>
    </div>
}

@section Scripts {
<script>
const news = @Html.Raw(ViewBag.News ?? "{}");
const comments = @Html.Raw(ViewBag.Comments ?? "[]");
const newsId = @ViewBag.NewsId;

document.getElementById('newsDetail').innerHTML = `
<h2>${news.title}</h2>
<div class="text-muted mb-3"><i class="bi bi-eye"></i> ${news.viewCount} görüntülenme</div>
${news.imagePath ? `<img src="${news.imagePath}" class="img-fluid rounded mb-3" style="max-height:400px;width:100%;object-fit:cover" onerror="this.style.display='none'">` : ''}
<p>${news.content}</p>`;

const clist = document.getElementById('commentList');
if (!comments || comments.length === 0) {
    clist.innerHTML = '<p class="text-muted">Henüz yorum yok.</p>';
} else {
    comments.forEach(c => {
        clist.innerHTML += `<div class="border-start border-danger ps-3 mb-2">
            <strong>${c.userName ?? 'Kullanıcı'}</strong> <small class="text-muted">${new Date(c.createdDate).toLocaleDateString('tr-TR')}</small>
            <p class="mb-0">${c.text}</p></div>`;
    });
}

function addComment() {
    const text = document.getElementById('commentText').value;
    if (!text) return;
    $.ajax({
        url: '/api/comment', type: 'POST',
        contentType: 'application/json',
        data: JSON.stringify({ text, newsId }),
        success: () => location.reload(),
        error: () => alert('Yorum eklenemedi.')
    });
}
</script>
}
